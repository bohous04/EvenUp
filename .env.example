# ── EvenUp configuration ─────────────────────────────────────────────────────
# Copy to `.env` and fill in. See docs/SELF_HOSTING.md for details.

# Database (PostgreSQL)
DATABASE_URL=postgresql://evenup:evenup@localhost:5432/evenup
POSTGRES_USER=evenup
POSTGRES_PASSWORD=evenup
POSTGRES_DB=evenup

# Encryption key for secrets at rest (BYO OpenRouter keys + IBANs), AES-256-GCM.
# Generate one: `openssl rand -base64 32`  (or a 64-char hex string)
ENCRYPTION_KEY=

# Auth (Better Auth). Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated emails auto-promoted to instance admin on sign-in (management
# dashboard at /admin). Leave empty for no admins.
# ADMIN_EMAILS=you@example.com

# OAuth providers (optional). Apple required for iOS App Store.
# NEXT_PUBLIC_* are inlined at BUILD time — set them before `next build`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=

# Sign In with Apple. Requires a paid Apple Developer Program membership.
# APPLE_SERVICES_ID is the Services ID (web OAuth client), NOT the bundle id.
# APPLE_PRIVATE_KEY is the contents of the AuthKey_XXXXXXXXXX.p8 file; newlines
# may be written as literal \n. The .p8 can only be downloaded once.
APPLE_SERVICES_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# company.lnrt.evenup is the reference app's bundle id, not a generic default.
# If you ship your own iOS app under a different bundle id, set it here —
# otherwise native Sign In with Apple silently fails (audience mismatch) while
# web sign-in keeps working (it uses APPLE_SERVICES_ID instead).
APPLE_BUNDLE_ID=company.lnrt.evenup
# Build-time, like NEXT_PUBLIC_GOOGLE_ENABLED above — set before `next build`.
NEXT_PUBLIC_APPLE_ENABLED=

# Email (magic links). Configure ONE of the two; without either, links are
# logged to the server console (dev only).
#  A) Resend (easiest — free tier, no domain needed for testing):
RESEND_API_KEY=
#  B) SMTP (any provider, good for self-hosting):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address. For Resend testing without a verified domain, keep the default
# (onboarding@resend.dev) and send to your own account email.
EMAIL_FROM=EvenUp <onboarding@resend.dev>

# Object storage (S3 / MinIO) for receipt images
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=evenup
STORAGE_SECRET_KEY=evenup-secret
STORAGE_BUCKET=evenup-receipts
STORAGE_REGION=us-east-1

# Days to retain the receipt image before the cleanup cron deletes it (privacy).
RECEIPT_RETENTION_DAYS=30

# Shared secret for the receipt-cleanup scheduled task's HTTP endpoint.
# Generate one: `openssl rand -base64 32`
CRON_SECRET=

# OCR (OpenRouter). Keys are per-user (BYO) — this is just the default model + base URL.
DEFAULT_OCR_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# FX rates provider (daily, cached). Frankfurter-style free source by default.
FX_PROVIDER_URL=https://api.frankfurter.app

# Dev/E2E only: echo magic links to /api/dev/magic-link for local sign-in.
# AUTH_DEV_ECHO=true
