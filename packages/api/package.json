{
  "name": "@evenup/api",
  "version": "0.0.0",
  "private": true,
  "description": "EvenUp tRPC API: type-safe routers, zod validation, encryption, OCR adapter. Uses @evenup/core for all math.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./trpc": {
      "types": "./src/trpc.ts",
      "default": "./src/trpc.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@evenup/core": "workspace:*",
    "@evenup/db": "workspace:*",
    "@evenup/i18n": "workspace:*",
    "@trpc/server": "^11.0.0",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
