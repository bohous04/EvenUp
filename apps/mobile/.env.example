# Copy to `apps/mobile/.env`. Expo inlines EXPO_PUBLIC_* vars at bundle time.

# The EvenUp API/web server the app talks to. For a dev build on a physical
# phone this must be reachable from the device — use your Mac's LAN IP (NOT
# localhost), e.g. http://192.168.0.189:3000, or a deployed URL.
EXPO_PUBLIC_API_URL=http://192.168.0.189:3000

# Set after `eas init` (it prints the project id). Used by app.config.ts.
# EAS_PROJECT_ID=
