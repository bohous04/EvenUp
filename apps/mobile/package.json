{
  "name": "@evenup/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "install": {
      "//": "Pinned to @types/react 19 to keep one version across the monorepo (web is React 19); dev-only, does not affect the native build.",
      "exclude": [
        "@types/react"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src",
    "test:e2e": "maestro test .maestro"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.0",
    "@better-auth/expo": "^1.2.9",
    "@evenup/api": "workspace:*",
    "@evenup/core": "workspace:*",
    "@evenup/i18n": "workspace:*",
    "@expo/vector-icons": "^14.0.0",
    "@tanstack/react-query": "^5.62.7",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.2.9",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
    "expo-dev-client": "~5.0.0",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.0",
    "expo-modules-core": "~2.2.3",
    "expo-network": "~7.0.5",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "superjson": "^2.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3"
  }
}
